    <DTS:Executable
      DTS:refId="Package\SQLT_Log_Bad_Completion_Times"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Execute SQL Task"
      DTS:DTSID="{17AE6825-7A42-4E43-BFB1-13CF49F90C95}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="SQLT_Log_Bad_Completion_Times"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{760AE522-249C-4384-8571-64D67BB8430B}"
          SQLTask:SqlStatementSource="  INSERT INTO dbo.Err_FactSalesCompletion_BadTime&#xA;(&#xA;    transaction_id,&#xA;    accm_txn_create_time,&#xA;    accm_txn_complete_time,&#xA;    error_reason&#xA;)&#xA;SELECT&#xA;    f.transaction_id,&#xA;    f.accm_txn_create_time,&#xA;    s.accm_txn_complete_time,&#xA;    N'Completion time is earlier than create time'&#xA;FROM dbo.FactSales f&#xA;INNER JOIN RetailStageDB.dbo.stg_FactSalesCompletion s&#xA;    ON f.transaction_id = s.transaction_id&#xA;WHERE s.accm_txn_complete_time &lt; f.accm_txn_create_time;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
    <DTS:Executable
      DTS:refId="Package\SQLT_Log_Missing_TxnIds"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Execute SQL Task"
      DTS:DTSID="{0F1D881A-2D57-4B07-8E65-A7143B812E2E}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="SQLT_Log_Missing_TxnIds"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{760AE522-249C-4384-8571-64D67BB8430B}"
          SQLTask:SqlStatementSource="INSERT INTO dbo.Err_FactSalesCompletion_NotFound&#xA;(&#xA;    transaction_id,&#xA;    accm_txn_complete_time,&#xA;    error_reason&#xA;)&#xA;SELECT&#xA;    s.transaction_id,&#xA;    s.accm_txn_complete_time,&#xA;    N'Transaction id not found in FactSales'&#xA;FROM RetailStageDB.dbo.stg_FactSalesCompletion s&#xA;LEFT JOIN dbo.FactSales f&#xA;    ON s.transaction_id = f.transaction_id&#xA;WHERE f.transaction_id IS NULL;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
    <DTS:Executable
      DTS:refId="Package\SQLT_Truncate_CompletionStage"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Execute SQL Task"
      DTS:DTSID="{1E3B72F5-B2CD-437F-BA4E-5444D5E3E9D1}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="SQLT_Truncate_CompletionStage"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{4A0F5677-14E3-4F30-9F60-FDAC12379527}"
          SQLTask:SqlStatementSource="TRUNCATE TABLE dbo.stg_FactSalesCompletion;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
    <DTS:Executable
      DTS:refId="Package\SQLT_Update_FactSales_Accumulating"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Execute SQL Task"
      DTS:DTSID="{B6A1AB4D-8CA1-4B6B-B089-24004294401B}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="SQLT_Update_FactSales_Accumulating"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{760AE522-249C-4384-8571-64D67BB8430B}"
          SQLTask:SqlStatementSource="UPDATE f&#xA;SET&#xA;    f.accm_txn_complete_time = s.accm_txn_complete_time,&#xA;    f.txn_process_time_hours =&#xA;        CAST(&#xA;            DATEDIFF(SECOND, f.accm_txn_create_time, s.accm_txn_complete_time) / 3600.0&#xA;            AS DECIMAL(18,2)&#xA;        )&#xA;FROM dbo.FactSales f&#xA;INNER JOIN RetailStageDB.dbo.stg_FactSalesCompletion s&#xA;    ON f.transaction_id = s.transaction_id&#xA;WHERE s.accm_txn_complete_time &gt;= f.accm_txn_create_time&#xA;  AND&#xA;  (&#xA;      f.accm_txn_complete_time IS NULL&#xA;      OR f.accm_txn_complete_time &lt;&gt; s.accm_txn_complete_time&#xA;  );" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
    <DTS:Executable
      DTS:refId="Package\SQLT_Validate_Accumulating_Update"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Execute SQL Task"
      DTS:DTSID="{9C3A4970-87A2-4981-A509-CBE705192A3A}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="SQLT_Validate_Accumulating_Update"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{760AE522-249C-4384-8571-64D67BB8430B}"
          SQLTask:SqlStatementSource="SELECT&#xA;    COUNT(*) AS CompletedRows&#xA;FROM dbo.FactSales&#xA;WHERE accm_txn_complete_time IS NOT NULL;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
  </DTS:Executables>
