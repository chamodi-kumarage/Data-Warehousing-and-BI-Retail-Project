    <DTS:Executable
      DTS:refId="Package\SQLT Load DimDate"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Execute SQL Task"
      DTS:DTSID="{75CE42BA-8566-4E17-BDBB-1DE07FE8923D}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="SQLT Load DimDate"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{51513FB6-6099-4EC2-8772-7876C1AC88E6}"
          SQLTask:SqlStatementSource="WITH d AS&#xA;(&#xA;    SELECT CAST('2020-01-01' AS DATE) AS FullDate&#xA;    UNION ALL&#xA;    SELECT DATEADD(DAY, 1, FullDate)&#xA;    FROM d&#xA;    WHERE FullDate &lt; '2025-12-31'&#xA;)&#xA;INSERT INTO dbo.DimDate&#xA;(&#xA;    DateKey,&#xA;    FullDate,&#xA;    CalendarYear,&#xA;    CalendarQuarter,&#xA;    MonthNumber,&#xA;    MonthName,&#xA;    DayOfMonth,&#xA;    DayName,&#xA;    WeekOfYear,&#xA;    IsWeekend&#xA;)&#xA;SELECT&#xA;    YEAR(d.FullDate) * 10000 + MONTH(d.FullDate) * 100 + DAY(d.FullDate),&#xA;    d.FullDate,&#xA;    YEAR(d.FullDate),&#xA;    DATEPART(QUARTER, d.FullDate),&#xA;    MONTH(d.FullDate),&#xA;    DATENAME(MONTH, d.FullDate),&#xA;    DAY(d.FullDate),&#xA;    DATENAME(WEEKDAY, d.FullDate),&#xA;    DATEPART(WEEK, d.FullDate),&#xA;    CASE WHEN DATENAME(WEEKDAY, d.FullDate) IN ('Saturday','Sunday') THEN 1 ELSE 0 END&#xA;FROM d&#xA;WHERE NOT EXISTS&#xA;(&#xA;    SELECT 1&#xA;    FROM dbo.DimDate dd&#xA;    WHERE dd.DateKey = YEAR(d.FullDate) * 10000 + MONTH(d.FullDate) * 100 + DAY(d.FullDate)&#xA;)&#xA;OPTION (MAXRECURSION 3000);" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
  </DTS:Executables>
